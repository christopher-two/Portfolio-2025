---
import type { Project } from '../data/portfolio';

interface Props {
  project: Project;
  index: number;
}

const { project, index } = Astro.props;
---

<a class="project-card" href={`/projects/${project.slug}`}>
  <div class="project-card-top">
    <span>{String(index + 1).padStart(2, '0')} / case study</span>
    <span>{project.categories?.[0] ?? 'Producto'}</span>
  </div>
  <div>
    <h2>{project.title}</h2>
    <p>{project.description}</p>
  </div>
  <div class="project-card-footer">
    <div class="detail-meta">
      {project.tags.slice(0, 4).map((tag) => <span class="tag">{tag}</span>)}
    </div>
    <span class="project-card-arrow" aria-hidden="true">↗</span>
  </div>
</a>
