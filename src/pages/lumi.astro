---
import BaseLayout from '../layouts/BaseLayout.astro';
import BrandPage from '../components/BrandPage.astro';

const sections = [
  { letter: 'L', title: 'UZ', description: 'Iluminando ideas con simplicidad. Claridad en cada función.' },
  { letter: 'U', title: 'TILIDAD', description: 'Herramientas que resuelven problemas reales. Sin adornos innecesarios.' },
  { letter: 'M', title: 'AGIA', description: 'La tecnología avanzada es indistinguible de la magia. Sorprende en cada interacción.' },
  { letter: 'I', title: 'NTELIGENCIA', description: 'Potenciando la creatividad humana con IA. Tus ideas, multiplicadas.' },
];
---

<BaseLayout title="Lumi · Christopher Two" description="Lumi es un generador de códigos QR impulsado por IA dentro del laboratorio de experimentos Daelia.">
  <BrandPage name="Lumi" kicker="Daelia experiments · AI QR" intro="Un generador de códigos QR impulsado por IA, diseñado para convertir una idea en una pieza lista para compartir." sections={sections} tone="lumi" />
</BaseLayout>
