---
import BaseLayout from '../layouts/BaseLayout.astro';
import { childhoodDream, goals } from '../features/bio/domain/bio.content';
import profileImage from '../assets/images/IMG_6195.jpg';
---

<BaseLayout title="Sobre mí · Christopher Two" description="Conoce a Christopher Alejandro Maldonado Chávez, desarrollador multiplataforma especializado en Kotlin, Android y Web.">
  <section class="page-intro">
    <div class="wrap">
      <span class="eyebrow">Sobre mí · 01</span>
      <h1 class="section-title">Un ingeniero con ganas de mover las cosas.</h1>
      <p>Desarrollador multiplataforma especializado en Kotlin, Jetpack Compose, arquitectura limpia y productos digitales que resuelven problemas concretos.</p>
    </div>
  </section>
  <article class="article">
    <img class="profile-image" src={profileImage.src} alt="Christopher Alejandro Maldonado Chávez" width="725" height="967" />
    <h2>{childhoodDream.question}</h2>
    <p>{childhoodDream.answer}</p>
    <h2>Hacia dónde voy</h2>
    {goals.map((goal) => <section class="bio-goal"><span class="mono">{goal.term}</span><h3>{goal.meta}</h3><p>{goal.motivation}</p><p><strong>Estrategia:</strong> {goal.strategy}</p></section>)}
  </article>
</BaseLayout>
