{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [".astro/types.d.ts", "src/pages/**/*.astro", "src/components/**/*.astro", "src/layouts/**/*.astro", "src/styles/**/*.css", "src/data/**/*.ts", "src/lib/data.ts", "src/lib/r2.ts", "src/env.d.ts", "worker-configuration.d.ts"],
  "exclude": ["node_modules", "src/app", "src/features", "src/hooks", "src/components/ui"]
}
